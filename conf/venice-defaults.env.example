# Venice.ai default settings for Agent Zero
# Copy to .env or merge into usr/.env, then set API_KEY_VENICE with your Venice.ai key.
# See A0_VENICEAI.md for full setup.
#
# Chat: strong model (mid/top tier)
A0_SET_chat_model_provider=venice
A0_SET_chat_model_name=mistral-31-24b
#
# Utility: small model to save quota
A0_SET_util_model_provider=venice
A0_SET_util_model_name=qwen3-4b
#
# Browser: vision + function-calling model
A0_SET_browser_model_provider=venice
A0_SET_browser_model_name=mistral-31-24b
#
# Required: your Venice.ai API key (get from https://venice.ai)
# API_KEY_VENICE=your_venice_api_key_here
